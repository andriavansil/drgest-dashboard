// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid())
  email String @unique
  password   String
  name  String
  speciality String?
  role String?
  img String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  statusId   Int

  status    Status @relation(fields: [statusId], references: [id])

  patients   Patient[]
  appointments Appointment[]
  attachments Attachment[]
  devices   Device[]
  syncLogs   SyncLog[]
  auditLogs  AuditLog[]
  notifications Notification[]
  permissions Permission[]
}

model Patient {
  id  Int @id @default(autoincrement())
  userId  String
  name String
  contact  String
  email String?
  birthday DateTime
  sex  Sexo
  address  String?
  bloodType String?
  medicalHistory String?
  medications   String?
  notes String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  statusId Int

  user User  @relation(fields: [userId], references: [id])
  status  Status @relation(fields: [statusId], references: [id])

  appointments  Appointment[]
  attachments   Attachment[]
}

model Appointment {
  id Int   @id @default(autoincrement())
  userId  String
  patientId Int
  date   DateTime
  type   String?
  local   String?
  reason  String?
  diagnosis String?
  medications  String?
  observations String?
  cancellationDate  DateTime?
  cancellationReason String?
  originAppointment  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  statusId Int

  user   User @relation(fields: [userId], references: [id])
  patient  Patient   @relation(fields: [patientId], references: [id])
  status  Status   @relation(fields: [statusId], references: [id])

  attachments  Attachment[]
}

model Attachment {
  id Int   @id @default(autoincrement())
  userId String
  patientId   Int?
  appointmentId Int?
  filePath   String
  description  String?
  fileType   String?
  createdAt   DateTime  @default(now())
  statusId   Int

  user  User @relation(fields: [userId], references: [id])
  patient    Patient   @relation(fields: [patientId], references: [id])
  appointment  Appointment @relation(fields: [appointmentId], references: [id])
  status Status   @relation(fields: [statusId], references: [id])
}

model Device {
  id  Int  @id @default(autoincrement())
  userId   String
  deviceName String
  lastSync  DateTime?
  Browsers String?
  createdAt DateTime @default(now())
  statusId  Int

  user    User   @relation(fields: [userId], references: [id])
  status   Status  @relation(fields: [statusId], references: [id])
}

model SyncLog {
  id  Int  @id @default(autoincrement())
  userId   String
  action   String
  entityType String
  entityId  String
  syncStatus String
  createdAt  DateTime @default(now())
  syncedAt  DateTime?
  statusId  Int

  user User   @relation(fields: [userId], references: [id])
  status   Status  @relation(fields: [statusId], references: [id])
}

model AuditLog {
  id  Int  @id @default(autoincrement())
  userId   String
  action   String
  entityType String
  entityId  String
  details   String?
  createdAt  DateTime @default(now())

  user User   @relation(fields: [userId], references: [id])
}

model Status {
  id Int  @id @default(autoincrement())
  name  String
  description  String?

  users  User[]
  patients   Patient[]
  appointments Appointment[]
  attachments  Attachment[]
  devices    Device[]
  syncLogs   SyncLog[]
  notifications Notification[]
  configurations Configuration[]
}

model Notification {
  id Int @id @default(autoincrement())
  userId  String
  title   String
  message  String
  type   String?
  read   Boolean  @default(false)
  createdAt DateTime @default(now())
  statusId Int

  user   User   @relation(fields: [userId], references: [id])
  status  Status  @relation(fields: [statusId], references: [id])
}

model Configuration {
  id Int @id @default(autoincrement())
  decConfig String
  value   String?
  system  String?
  statusId Int

  status  Status @relation(fields: [statusId], references: [id])
  permissions Permission[]
}

model Permission {
  id Int @id @default(autoincrement())
  userId  String
  configId Int

  user   User  @relation(fields: [userId], references: [id])
  config  Configuration @relation(fields: [configId], references: [id])
}

enum Sexo {
  Masculino
  Femenino
}
